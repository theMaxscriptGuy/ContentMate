APP_NAME=ContentMate API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_TO_FILE=true
LOG_FILE_PATH=logs/contentmate-api.log
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

POSTGRES_DSN=postgresql+asyncpg://contentmate:contentmate@localhost:5432/contentmate
REDIS_URL=redis://localhost:6379/0

YOUTUBE_MIN_DURATION_SECONDS=301
YOUTUBE_SCAN_LIMIT=0
YOUTUBE_CANDIDATE_POOL_SIZE=10
TRANSCRIPT_USE_YTDLP_FALLBACK=true

AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL_SECONDS=604800
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
DAILY_ANALYSIS_LIMIT=5
RATE_LIMIT_GLOBAL_REQUESTS_PER_MINUTE=300
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=30
RATE_LIMIT_PIPELINE_REQUESTS_PER_HOUR=20

OPENAI_API_KEY=your_openai_api_key
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_ANALYSIS_MAX_TRANSCRIPT_CHARS=60000
